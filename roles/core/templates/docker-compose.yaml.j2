services:
  alloy:
    image: grafana/alloy:${ALLOY_VERSION}
    container_name: alloy
    restart: unless-stopped

    pid: host
    network_mode: host
    # privileged: true
    
    volumes:
      - ./alloy/config.alloy:/etc/alloy/config.alloy

      # For Node Exporter
      - /:/host/root:ro
      - /sys:/host/sys:ro
      - /proc:/host/proc:ro

      # For CAdvisor
      - /:/rootfs:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - /var/run:/var/run:ro
      - /sys:/sys:ro
      - /var/lib/docker/:/var/lib/docker:ro
      - /dev/disk/:/dev/disk:ro

    command: 
      - 'run'
      - '--disable-reporting'
      - '--server.http.listen-addr=127.0.0.1:${ALLOY_PORT}'
      - '--storage.path=/var/lib/alloy/data'
      - '/etc/alloy/config.alloy'
    depends_on:
    #   - loki
      - prometheus
    deploy:
      resources:
        limits:
          cpus: "0.5"
          memory: 512M
        reservations:
          memory: 256M

  prometheus:
    image: prom/prometheus:${PROMETHEUS_VERSION}
    container_name: prometheus
    restart: unless-stopped

    volumes:
      - ./prometheus/prometheus.yml:/etc/prometheus/prometheus.yml
      - ./prometheus/targets:/etc/prometheus/targets
      - prometheus_data:/prometheus
    command:
      - '--config.file=/etc/prometheus/prometheus.yml'
      - '--storage.tsdb.path=/prometheus'
      - '--storage.tsdb.retention.time=${PROMETHEUS_RETENTION_TIME}'
      - '--storage.tsdb.retention.size=${PROMETHEUS_RETENTION_SIZE}'
      - '--web.enable-lifecycle'
      - '--web.enable-remote-write-receiver'
    ports:
      - "127.0.0.1:${PROMETHEUS_PORT}:9090"
    networks:
      - monitoring-layer
    
    deploy:
      resources:
        limits:
          cpus: "1.0"
          memory: 512M
        reservations:
          memory: 256M

  grafana:
    image: grafana/grafana:${GRAFANA_VERSION}
    container_name: grafana
    restart: unless-stopped
    environment:
      - GF_SECURITY_ADMIN_USER=${GRAFANA_ADMIN_USER}
      - GF_SECURITY_ADMIN_PASSWORD=${GRAFANA_ADMIN_PASSWORD}
      - GF_USERS_ALLOW_SIGN_UP=false
      - GF_SERVER_DOMAIN=${GRAFANA_DOMAIN}
      - GF_SERVER_ROOT_URL=${GRAFANA_ROOT_URL}
    expose:
      - "3000"
    volumes:
      - grafana_data:/var/lib/grafana
      - ./grafana/provisioning:/etc/grafana/provisioning
      - ./grafana/dashboards_json:/etc/grafana/dashboards
    networks:
      - monitoring-layer
    deploy:
      resources:
        limits:
          cpus: "1.0"
          memory: 512M
        reservations:
          memory: 128M

  minio:
    image: minio/minio:${MINIO_VERSION}
    container_name: minio
    restart: unless-stopped
    
    expose:
      - "${MINIO_PORT_API}"
      - "${MINIO_PORT_UI}"
    ports:
      - "127.0.0.1:${MINIO_PORT_UI}:${MINIO_PORT_UI}"
    command: server /data --console-address ":${MINIO_PORT_UI}"
    environment:
      MINIO_ROOT_USER: ${MINIO_ROOT_USER}
      MINIO_ROOT_PASSWORD: ${MINIO_ROOT_PASSWORD}
    
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:${MINIO_PORT_API}/minio/health/live"]
      interval: 10s
      timeout: 10s
      retries: 3
      start_period: 10s

    volumes:
      - minio_data:/data
    networks:
      - monitoring-layer

    deploy:
      resources:
        limits:
          cpus: "0.5"
          memory: 512M
        reservations:
          memory: 256M

  minio-create-bucket:
    image: minio/mc
    depends_on:
      minio:
        condition: service_healthy
    entrypoint: >
      /bin/sh -c "
      /usr/bin/mc alias set myminio http://minio:${MINIO_PORT_API} ${MINIO_ROOT_USER} ${MINIO_ROOT_PASSWORD};
      /usr/bin/mc mb --ignore-existing myminio/loki-data;
      exit 0;
      "
    networks:
      - monitoring-layer

  loki-init:
    image: alpine:latest
    volumes:
      - loki_wal:/loki
    command: chown -R 10001:10001 /loki

  loki:
    image: grafana/loki:${LOKI_VERSION}
    container_name: loki
    restart: unless-stopped

    volumes:
      - loki_wal:/loki/wal
      - ./loki/loki.yml:/etc/loki/local-config.yaml
    ports:
      - "127.0.0.1:${LOKI_PORT}:3100"
    depends_on:
      loki-init:
        condition: service_completed_successfully
      minio:
        condition: service_healthy
    networks:
      - monitoring-layer

    deploy:
      resources:
        limits:
          cpus: "0.5"
          memory: 512M
        reservations:
          memory: 256M
    
  blackbox-exporter:
    image: prom/blackbox-exporter:${BLACKBOX_VERSION}
    container_name: blackbox-exporter
    restart: unless-stopped
    
    ports:
      - "127.0.0.1:${BLACKBOX_PORT}:9115"
    volumes:
      - ./blackbox/blackbox.yml:/config/blackbox.yml
    command:
      - '--config.file=/config/blackbox.yml'

    deploy:
      resources:
        limits:
          memory: 512M
          cpus: "0.5"
        reservations:
          memory: 256M

    networks:
      - monitoring-layer

  nginx:
    image: nginx:stable-alpine
    container_name: nginx
    restart: unless-stopped

    ports:
      - "80:80"
    depends_on: ["prometheus", "loki", "grafana"]
    volumes:
      - ./nginx/nginx_proxy.conf:/etc/nginx/conf.d/default.conf:ro
      - ./nginx/.htpasswd:/etc/nginx/.htpasswd:ro
    networks:
      - monitoring-layer

    deploy:
      resources:
        limits:
          memory: 512M
          cpus: "0.5"
        reservations:
          memory: 256M

volumes:
  prometheus_data:
  grafana_data:
  minio_data:
  loki_wal:

networks:
  monitoring-layer:
    external: true

apiVersion: 1

datasources:
  - name: Prometheus
    type: prometheus
    access: proxy
    url: http://{{ vault_prometheus_addr }}:{{ core_prometheus_port }}
    isDefault: true
    editable: false
    jsonData:
      timeInterval: "10s"


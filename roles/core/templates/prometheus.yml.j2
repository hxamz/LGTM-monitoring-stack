global:
  scrape_interval: 10s
  evaluation_interval: 15s

scrape_configs:
  - job_name: blackbox-http
    metrics_path: /probe
    params:
      module: [http_2xx]

    file_sd_configs:
      - files:
          - /etc/prometheus/targets/blackbox_targets.yml
        refresh_interval: 1m
        
    relabel_configs:
      # Get addr from targets and put it into URL parameter target
      - source_labels: [__address__]
        target_label: __param_target

      # Saving address in instance label for Grafana
      - source_labels: [__param_target]
        target_label: instance

      # Using blacbox exporter as proxy for address
      - target_label: __address__
        replacement: blackbox-exporter:{{ core_blackbox_port }}